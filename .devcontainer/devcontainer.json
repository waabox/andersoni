{
	"name": "Andersoni Dev",
	"build": {
		"dockerfile": "Dockerfile"
	},

	"runArgs": ["--name=andersoni"],

	"remoteEnv": {
		"JAVA_HOME": "/usr/lib/jvm/java-21-amazon-corretto"
	},

	"customizations": {
		"jetbrains": {
			"backend": "IntelliJ"
		},
		"vscode": {
			"extensions": [
				"vscjava.vscode-java-pack"
			]
		}
	},

	"remoteUser": "root"
}
